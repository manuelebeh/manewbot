# Copier vers .env et renseigner vos valeurs (ne jamais committer .env)
PREFIXE=.
NOM_OWNER=
# NUMERO_OWNER : chiffres WhatsApp sans 00 (ex. 221..., pas 00221...)
NUMERO_OWNER=
MODE=private
STICKER_PACK_NAME=Manewbot
STICKER_AUTHOR_NAME=
NOM_BOT=Manewbot

# Groupes WhatsApp à accès limité (JID complets, séparés par des virgules).
# Ex. RESTRICTED_GROUPS=120363314687943170@g.us,120363404635307998@g.us
RESTRICTED_GROUPS=

# Numéros ou JID autorisés dans ces groupes en plus du owner et des sudo (optionnel).
# Ex. RESTRICTED_GROUP_ALLOWLIST=221772430620
RESTRICTED_GROUP_ALLOWLIST=

# Obsolètes (ignorés par le code — utiliser COMMAND_REACT à la place) :
# AUTOREACT_MSG=
# AUTOREAD_MSG=
# DEV_NUMBERS=

# Groupes sans réaction automatique du bot (JID @g.us, séparés par des virgules).
# Ex. BLOCKED_AUTOREACT_GROUPS=120363314687943170@g.us,120363404635307998@g.us,120363398500341783@g.us
BLOCKED_AUTOREACT_GROUPS=

# Réaction emoji sur le message quand une commande s'exécute (on|off, vide = activé)
# COMMAND_REACT=off
COMMAND_REACT=

# Auth WhatsApp 100 % locale :
# Au premier lancement, scannez le QR code affiché dans le terminal.
# Les credentials seront stockés dans auth/principale/.
# Pour un second compte : appairez dans auth/<numero>/, puis enregistrez via commande owner.

# Optionnel : URL Postgres (sinon SQLite local)
# DATABASE=

# Clés API externes (commandes google, imdb, stickersearch, emix, meteo, shazam)
# GOOGLE_SEARCH_API_KEY=
# GOOGLE_SEARCH_CX=
# OMDB_API_KEY=
# TENOR_API_KEY=
# TENOR_EMOJI_API_KEY=
# OPENWEATHER_API_KEY=
# ACRCLOUD_HOST=identify-eu-west-1.acrcloud.com
# ACRCLOUD_ACCESS_KEY=
# ACRCLOUD_ACCESS_SECRET=

# APIs IA / capture web (commandes gpt, dalle, capture, … — laisser vide = désactivé)
# AI_API_BASE=https://votre-proxy-ia.example
# AI_TOXXIC_API_BASE=https://votre-proxy-secondaire.example
# AI_LLAMA_API_BASE=https://votre-proxy-llama.example
# SSWEB_API_BASE=   # optionnel, défaut = AI_API_BASE

# Services média / stickers (vide = commande désactivée sauf ezgif)
# OVL_API_BASE=https://api-ovl.koyeb.app
# REMINI_API_BASE=https://www.itzky.xyz
# QUOTELY_API_BASE=https://bot.lyo.su
# VYRO_API_BASE=https://inferenceengine.vyro.ai
# EZGIF_API_BASE=https://ezgif.com

# YouTube (song, video, yta, ytv) — défaut : proxy public vercel
# YOUTUBE_DL_API_BASE=https://you-tube-dl-psi.vercel.app
# Paroles (lyrics)
# LYRICS_API_BASE=https://api.delirius.store

# Chatbot (GET ?user_id=&text=) — vide = pas d'appel réseau même si chatbot activé en DB
# CHATBOT_API_BASE=https://votre-api.example/chatbot

# URLs tierces (défauts publics — surchargeables)
# WAIFU_PICS_API_BASE=https://api.waifu.pics/sfw
# CATBOX_UPLOAD_URL=https://catbox.moe/user/api.php
# DEFAULT_AVATAR_URL=https://files.catbox.moe/ulwqtr.jpg
# THEME_LIST_IMAGE_URL=https://files.catbox.moe/6xlk10.jpg
# EPHOTO360_BASE=https://en.ephoto360.com
# GITHUB_KOPEL_JSON_URL=https://raw.githubusercontent.com/iamriz7/kopel_/main/kopel.json
# WELCOME_IMAGE_URL=https://files.catbox.moe/82g8ey.jpg
# BOT_INFO_IMAGE_URL=https://files.catbox.moe/lojrxz.jpg
# VIDEO_QUOTE_PLACEHOLDER_URL=https://files.catbox.moe/8kvevz.jpg

# Owner : import stickers Telegram (commande tgs) — régénérer si exposé
# TELEGRAM_BOT_TOKEN=

# Postgres SSL (si DATABASE est défini)
# DATABASE_SSL_REJECT_UNAUTHORIZED=false
# DATABASE_SSL_CA=/chemin/vers/ca.pem

# Délai avant connexion WhatsApp principale (ms, défaut 45000)
# STARTUP_DELAY_MS=45000

# Production : désactive npm install auto au démarrage et les logs message détaillés par défaut
# NODE_ENV=production

# Logs console des messages entrants : off | minimal | full
# (vide = off en production, full en dev)
# LOG_MESSAGES=minimal

# Health check HTTP — par défaut : 127.0.0.1:3000 (non exposé sur Internet)
# VPS / panel : désactiver OU ne jamais ouvrir le port 3000 dans ufw / security group
ENABLE_HEALTH_CHECK=false
# HEALTH_PORT=3000
# HEALTH_BIND_HOST=127.0.0.1
# PaaS (Render/Heroku) uniquement si la plateforme l'exige :
# ENABLE_HEALTH_CHECK=true
# HEALTH_BIND_HOST=0.0.0.0
