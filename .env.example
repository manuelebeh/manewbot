# Copier vers .env et renseigner vos valeurs (ne jamais committer .env)
PREFIXE=.
NOM_OWNER=
# NUMERO_OWNER : chiffres WhatsApp sans 00 (ex. 221..., pas 00221...)
NUMERO_OWNER=
MODE=private
STICKER_PACK_NAME=Manewbot
STICKER_AUTHOR_NAME=
NOM_BOT=Manewbot

# Groupes WhatsApp à accès limité (JID complets, séparés par des virgules).
# Ex. RESTRICTED_GROUPS=120363314687943170@g.us,120363404635307998@g.us
RESTRICTED_GROUPS=

# Numéros ou JID autorisés dans ces groupes en plus du owner et des sudo (optionnel).
# Ex. RESTRICTED_GROUP_ALLOWLIST=221772430620
RESTRICTED_GROUP_ALLOWLIST=

# Groupes sans réaction automatique du bot (JID @g.us, séparés par des virgules).
# Ex. BLOCKED_AUTOREACT_GROUPS=120363314687943170@g.us,120363404635307998@g.us,120363398500341783@g.us
BLOCKED_AUTOREACT_GROUPS=

# Réaction emoji sur le message quand une commande s'exécute (on|off, vide = activé)
# COMMAND_REACT=off
COMMAND_REACT=

# Auth WhatsApp 100 % locale :
# Au premier lancement, scannez le QR code affiché dans le terminal.
# Les credentials seront stockés dans auth/principale/.
# Pour un second compte : appairez dans auth/<numero>/, puis enregistrez via commande owner.

# Optionnel : URL Postgres (sinon SQLite local)
# DATABASE=

# Clés API externes (commandes google, imdb, stickersearch, emix, meteo, shazam)
# GOOGLE_SEARCH_API_KEY=
# GOOGLE_SEARCH_CX=
# OMDB_API_KEY=
# TENOR_API_KEY=
# TENOR_EMOJI_API_KEY=
# OPENWEATHER_API_KEY=
# ACRCLOUD_HOST=identify-eu-west-1.acrcloud.com
# ACRCLOUD_ACCESS_KEY=
# ACRCLOUD_ACCESS_SECRET=

# Health check HTTP — par défaut : 127.0.0.1:3000 (non exposé sur Internet)
# VPS / panel : désactiver OU ne jamais ouvrir le port 3000 dans ufw / security group
ENABLE_HEALTH_CHECK=false
# HEALTH_PORT=3000
# HEALTH_BIND_HOST=127.0.0.1
# PaaS (Render/Heroku) uniquement si la plateforme l'exige :
# ENABLE_HEALTH_CHECK=true
# HEALTH_BIND_HOST=0.0.0.0
